{
  "description": "Quantum operations metrics",
  "editable": true,
  "panels": [
    {
      "title": "QRNG Requests/sec",
      "type": "timeseries",
      "targets": [{"expr": "rate(cfzt_quantum_rng_requests_total[5m])", "legendFormat": "{{backend}}", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "title": "QRNG Latency",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.99, rate(cfzt_quantum_rng_duration_seconds_bucket[5m]))", "legendFormat": "P99", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "title": "QKD QBER",
      "type": "timeseries",
      "targets": [{"expr": "cfzt_quantum_qber", "legendFormat": "QBER", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "title": "QKD Key Length",
      "type": "timeseries",
      "targets": [{"expr": "cfzt_quantum_key_length", "legendFormat": "bits", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "title": "VQC Circuit Depth",
      "type": "timeseries",
      "targets": [{"expr": "cfzt_quantum_vqc_circuit_depth", "legendFormat": "depth", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
    },
    {
      "title": "Quantum Backend Health",
      "type": "stat",
      "targets": [{"expr": "cfzt_quantum_backend_health", "legendFormat": "{{backend}}", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    }
  ],
  "tags": ["cfzt", "quantum"],
  "title": "CFZT Quantum Operations",
  "uid": "cfzt-quantum"
}

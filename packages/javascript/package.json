{
  "name": "continuous-face-zero-trust-js",
  "version": "1.0.0",
  "description": "Continuous Face Zero Trust JavaScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zero-trust",
    "face-recognition",
    "post-quantum-cryptography",
    "quantum-resistant",
    "authentication"
  ],
  "author": "CFZT Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cfzt/continuous-face-zero-trust"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "@noble/hashes": "^1.3.0",
    "@peculiar/asn1-x509": "^2.5.0",
    "axios": "^1.6.0",
    "jose": "^5.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}

include LICENSE
include README.md
include pyproject.toml
recursive-include src *.py *.pyi *.toml *.json
recursive-include tests *.py *.toml
recursive-include docs *.md *.rst
exclude .git
exclude .github
exclude __pycache__
exclude *.pyc
exclude .env
exclude .env.*
global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store
